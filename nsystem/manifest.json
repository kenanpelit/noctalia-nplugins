{
  "id": "nsystem",
  "name": "NSystem",
  "version": "0.1.0",
  "minNoctaliaVersion": "4.0.0",
  "author": "Kenan Pelit",
  "license": "MIT",
  "repository": "https://github.com/kenanpelit/noctalia-nplugins",
  "description": "Compact system console with live CPU, memory, disk, load, and quick process insights.",
  "tags": [
    "Bar",
    "Panel",
    "ControlCenter",
    "System"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "controlCenterWidget": "ControlCenterWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "watchdogInterval": 4000,
      "btopCommand": "kitty --class btop -e btop",
      "htopCommand": "kitty --class htop -e htop",
      "topCommand": "kitty --class top -e top"
    }
  }
}
