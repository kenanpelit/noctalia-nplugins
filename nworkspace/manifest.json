{
  "id": "nworkspace",
  "name": "NWorkspace",
  "version": "0.1.1",
  "minNoctaliaVersion": "4.0.0",
  "author": "Kenan Pelit",
  "official": false,
  "license": "MIT",
  "repository": "https://github.com/kenanpelit/noctalia-nplugins",
  "description": "Workspace radar with monitor-aware pills, live window counts, and a faster focus panel.",
  "tags": [
    "Bar",
    "Panel",
    "Productivity",
    "WindowManagement"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "labelMode": "index",
      "characterCount": 3,
      "hideEmpty": true,
      "followFocusedOutput": true,
      "showOutputName": false,
      "showWindowCount": false,
      "showPreviewDots": false,
      "maxPreviewDots": 4,
      "compact": true
    }
  }
}
